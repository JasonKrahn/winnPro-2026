{
  "name": "winnpro-2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "cms": "npx decap-server",
    "dev:all": "npm run dev & npm run cms",
    "cms-pull": "git pull && echo '\n=== CMS Updates Pulled ===\n' && git diff HEAD@{1} HEAD --name-status",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "spell-check": "cspell lint --config .cspellrc.json 'content/**/*.md' 'src/**/*.{tsx,ts}' README.md",
    "spell-check:fix": "cspell lint --config .cspellrc.json 'content/**/*.md' 'src/**/*.{tsx,ts}' README.md || true",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "decap-cms-app": "3.10.0",
    "dompurify": "^3.3.3",
    "framer-motion": "12.34.0",
    "gray-matter": "4.0.3",
    "lucide-react": "0.564.0",
    "marked": "^17.0.4",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "schema-dts": "1.1.5"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^4.41.6",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "cspell": "^9.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
